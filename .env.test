# Env vars needed at module-load time by code under test (e.g. pages/api/me.ts builds a JWKS URL
# from NEXT_PUBLIC_MYETM_URL when the module is first imported). Next.js does not load .env.local
# when NODE_ENV=test, so committed test-fixture values live here instead.
NEXT_PUBLIC_MYETM_URL=http://localhost:3002
